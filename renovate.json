{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "description": "Track Sure upstream releases in package.nix",
      "customType": "regex",
      "fileMatch": ["^package\\.nix$"],
      "matchStrings": [
        "version\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "depNameTemplate": "we-promise/sure",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Group flake input updates",
      "matchManagers": ["nix"],
      "groupName": "flake inputs",
      "schedule": ["every weekend"]
    },
    {
      "description": "Sure upstream releases — regenerate gemset after version bump",
      "matchDepNames": ["we-promise/sure"],
      "automerge": false,
      "schedule": ["at any time"],
      "postUpgradeTasks": {
        "commands": [
          "bash scripts/update-gemset.sh {{newVersion}}",
          "git add Gemfile Gemfile.lock .ruby-version gemset.nix package.nix"
        ],
        "fileFilters": [
          "Gemfile",
          "Gemfile.lock",
          ".ruby-version",
          "gemset.nix",
          "package.nix"
        ],
        "executionMode": "branch"
      }
    }
  ]
}
